<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.motorclub.mapper.McBenefitMapper">

    <resultMap id="McBenefitResult" type="McBenefit">
        <id property="benefitId" column="benefit_id"/>
        <result property="title" column="title"/>
        <result property="summary" column="summary"/>
        <result property="content" column="content"/>
        <result property="imageUrl" column="image_url"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectMcBenefitVo">
        select benefit_id, title, summary, content, image_url, sort, status,
               create_by, create_time, update_by, update_time, remark
        from mc_benefit
    </sql>

    <select id="selectMcBenefitById" parameterType="Long" resultMap="McBenefitResult">
        <include refid="selectMcBenefitVo"/>
        where benefit_id = #{benefitId}
    </select>

    <select id="selectMcBenefitList" parameterType="McBenefit" resultMap="McBenefitResult">
        <include refid="selectMcBenefitVo"/>
        <where>
            <if test="title != null and title != ''">
                and title like concat('%', #{title}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort asc, create_time desc
    </select>

    <select id="selectEnabledMcBenefitList" resultMap="McBenefitResult">
        <include refid="selectMcBenefitVo"/>
        where status = '0'
        order by sort asc, create_time desc
    </select>

    <insert id="insertMcBenefit" parameterType="McBenefit" useGeneratedKeys="true" keyProperty="benefitId">
        insert into mc_benefit (
            title, summary, content, image_url, sort, status,
            create_by, create_time, update_by, update_time, remark
        ) values (
            #{title}, #{summary}, #{content}, #{imageUrl}, #{sort}, #{status},
            #{createBy}, #{createTime}, #{updateBy}, #{updateTime}, #{remark}
        )
    </insert>

    <update id="updateMcBenefit" parameterType="McBenefit">
        update mc_benefit
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="content != null">content = #{content},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where benefit_id = #{benefitId}
    </update>

    <delete id="deleteMcBenefitByIds" parameterType="Long">
        delete from mc_benefit where benefit_id in
        <foreach collection="array" item="benefitId" open="(" separator="," close=")">
            #{benefitId}
        </foreach>
    </delete>

</mapper>
