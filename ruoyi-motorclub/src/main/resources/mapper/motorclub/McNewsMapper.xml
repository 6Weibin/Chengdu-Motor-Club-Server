<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.motorclub.mapper.McNewsMapper">

    <resultMap id="McNewsResult" type="McNews">
        <id property="newsId" column="news_id"/>
        <result property="title" column="title"/>
        <result property="tagName" column="tag_name"/>
        <result property="summary" column="summary"/>
        <result property="coverImageUrl" column="cover_image_url"/>
        <result property="content" column="content"/>
        <result property="publishTime" column="publish_time"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <resultMap id="McPortalNewsListResult" type="com.ruoyi.motorclub.domain.vo.McPortalNewsListVo">
        <id property="newsId" column="news_id"/>
        <result property="title" column="title"/>
        <result property="tagName" column="tag_name"/>
        <result property="summary" column="summary"/>
        <result property="coverImageUrl" column="cover_image_url"/>
        <result property="publishTime" column="publish_time"/>
    </resultMap>

    <resultMap id="McPortalNewsDetailResult" type="com.ruoyi.motorclub.domain.vo.McPortalNewsDetailVo">
        <id property="newsId" column="news_id"/>
        <result property="title" column="title"/>
        <result property="tagName" column="tag_name"/>
        <result property="summary" column="summary"/>
        <result property="coverImageUrl" column="cover_image_url"/>
        <result property="content" column="content"/>
        <result property="publishTime" column="publish_time"/>
    </resultMap>

    <sql id="selectMcNewsVo">
        select news_id, title, tag_name, summary, cover_image_url, content, publish_time, status,
               create_by, create_time, update_by, update_time, remark
        from mc_news
    </sql>

    <select id="selectMcNewsById" parameterType="Long" resultMap="McNewsResult">
        <include refid="selectMcNewsVo"/>
        where news_id = #{newsId}
    </select>

    <select id="selectMcNewsList" parameterType="McNews" resultMap="McNewsResult">
        <include refid="selectMcNewsVo"/>
        <where>
            <!-- 业务规则：普通新闻管理列表不展示逻辑删除数据。 -->
            and status != 'deleted'
            <if test="title != null and title != ''">
                and title like concat('%', #{title}, '%')
            </if>
            <if test="tagName != null and tagName != ''">
                and tag_name like concat('%', #{tagName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by publish_time desc, create_time desc
    </select>

    <select id="selectDeletedMcNewsList" parameterType="McNews" resultMap="McNewsResult">
        <include refid="selectMcNewsVo"/>
        <where>
            <!-- 业务规则：已删除新闻管理页面只展示逻辑删除数据。 -->
            and status = 'deleted'
            <if test="title != null and title != ''">
                and title like concat('%', #{title}, '%')
            </if>
            <if test="tagName != null and tagName != ''">
                and tag_name like concat('%', #{tagName}, '%')
            </if>
        </where>
        order by update_time desc, publish_time desc, create_time desc
    </select>

    <insert id="insertMcNews" parameterType="McNews" useGeneratedKeys="true" keyProperty="newsId">
        insert into mc_news (
            title, tag_name, summary, cover_image_url, content, publish_time, status,
            create_by, create_time, update_by, update_time, remark
        ) values (
            #{title}, #{tagName}, #{summary}, #{coverImageUrl}, #{content}, #{publishTime}, #{status},
            #{createBy}, #{createTime}, #{updateBy}, #{updateTime}, #{remark}
        )
    </insert>

    <update id="updateMcNews" parameterType="McNews">
        update mc_news
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="tagName != null">tag_name = #{tagName},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="coverImageUrl != null">cover_image_url = #{coverImageUrl},</if>
            <if test="content != null">content = #{content},</if>
            <if test="publishTime != null">publish_time = #{publishTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where news_id = #{newsId}
    </update>

    <update id="updateMcNewsStatus" parameterType="McNews">
        update mc_news
        set status = #{status},
            update_by = #{updateBy},
            update_time = #{updateTime}
        where news_id = #{newsId}
    </update>

    <select id="selectPortalNewsList" parameterType="com.ruoyi.motorclub.domain.dto.McPortalNewsQuery" resultMap="McPortalNewsListResult">
        select news_id, title, tag_name, summary, cover_image_url, publish_time
        from mc_news
        where status = '0'
          and status != 'deleted'
          and publish_time &lt;= now()
        order by publish_time desc, news_id desc
    </select>

    <select id="selectPortalNewsDetailById" parameterType="Long" resultMap="McPortalNewsDetailResult">
        select news_id, title, tag_name, summary, cover_image_url, content, publish_time
        from mc_news
        where news_id = #{newsId}
          and status = '0'
          and status != 'deleted'
          and publish_time &lt;= now()
    </select>

</mapper>
